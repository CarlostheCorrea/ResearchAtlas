OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o

# MCP server runs on a separate port from the main FastAPI app
MAIN_API_PORT=8000
MCP_SERVER_PORT=8001

# Data paths
DB_PATH=./data/research.db
PDF_DIR=./data/pdfs
VECTORSTORE_DIR=./data/vectorstore

# OpenAI embedding model used for Chroma indexing and retrieval
EMBEDDING_MODEL=text-embedding-3-small
# Optional: reduce embedding size to save storage/cost
# EMBEDDING_DIMENSIONS=1536

# Image generation model
OPENAI_IMAGE_MODEL=gpt-image-1

# Q/A orchestrator
QA_ASSETS_DIR=./data/qa_assets
QA_MAX_TOOL_STEPS=4
QA_ASSET_MAX_AGE_HOURS=24

# Search defaults
DEFAULT_MAX_RESULTS=20
DEFAULT_YEAR_FROM=2022

# Pre-filter settings
KEYWORD_FILTER_ENABLED=true
MIN_ABSTRACT_LENGTH=50

# ── Arize Phoenix observability ───────────────────────────────────────────────
# Run the Phoenix collector in a second terminal before starting the app:
#   python -m phoenix.server.main serve
# Then open http://localhost:6006 to view traces and eval scores.
#
# Leave PHOENIX_COLLECTOR_ENDPOINT unset to use the default localhost:6006.
# To use Phoenix Cloud instead: https://app.phoenix.arize.com
# PHOENIX_COLLECTOR_ENDPOINT=https://app.phoenix.arize.com
# PHOENIX_API_KEY=your_phoenix_cloud_key_here
PHOENIX_PROJECT_NAME=researchatlas

# ── LLM-as-judge evaluation ───────────────────────────────────────────────────
# Set to false to skip the LLM judge and use a fast local heuristic instead.
# Disabling saves ~2 extra OpenAI calls per Q/A session.
QA_JUDGE_ENABLED=true

# Set to false to skip the automatic repair pass when the judge finds failures.
# Disabling saves time but means weak answers are returned as-is.
QA_REPAIR_ENABLED=true
